# --- Firebase (web client) ---
# From Firebase Console → Project Settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Firebase Admin (backend) ---
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Polar ---
# From polar.sh/dashboard → API Keys and Webhooks
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_PRODUCT_LITE=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_STUDIO=

# --- AI providers ---
GEMINI_API_KEY=                 # Required — generates all images (Gemini 2.0 Flash)
ANTHROPIC_API_KEY=              # Optional — Claude enhances prompts; app works without it

# --- App ---
APP_BASE_URL=http://localhost:5173
CRON_SECRET=
NODE_ENV=development
