{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/bundle" }
  ],
  "functions": {
    "api/bundle.cjs": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/generate-daily",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
